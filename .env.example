# Apify (server-side) — Instagram data is fetched via Apify Actors.
# Get your token at https://console.apify.com/settings/integrations
APIFY_TOKEN=your_apify_token_here

# Passcode for the login screen (server-side). Defaults to the built-in value if unset.
APP_PASSCODE=heavenzy1997@gmail.com

# Supabase (client-side, embedded at build time). Leave blank to fall back to local browser storage.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side Supabase (cron / scheduled publishing). Service role bypasses RLS.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Secret for Vercel cron requests (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=your_random_cron_secret

# Instagram Business Login (OAuth) — get app secret from Meta App Dashboard → Instagram → Business login settings
INSTAGRAM_APP_ID=2210054946503834
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_OAUTH_REDIRECT_URI=https://www.drbossing.com/

# Client-side OAuth (embedded at build time). Redirect URI must match Meta dashboard exactly.
VITE_INSTAGRAM_APP_ID=2210054946503834
VITE_INSTAGRAM_OAUTH_REDIRECT_URI=https://www.drbossing.com/
