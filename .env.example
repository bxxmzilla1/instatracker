# Apify (server-side) — Instagram data is fetched via Apify Actors.
# Get your token at https://console.apify.com/settings/integrations
APIFY_TOKEN=your_apify_token_here

# Passcode for the login screen (server-side). Defaults to the built-in value if unset.
APP_PASSCODE=heavenzy1997@gmail.com

# Supabase (client-side, embedded at build time). Leave blank to fall back to local browser storage.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
